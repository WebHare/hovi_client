  PUBLIC RECORD FUNCTION GetReferences(STRING type, STRING orgid, STRING rowkey)
  {
    IF (type = "organization")
      THROW NEW Exception(`Cannot query references of type ${EncodeJSON(type)}`);

    RECORD rec := this->Get(`/organization/${EncodeURL(orgid)}/${type}/${rowkey}/references`).data;
    IF (CellExists(rec, "product"))
    {
      rec.product := EnforceStructure(
          [ [ userkey :=        ""
            , producttype :=    ""
            , productname :=    DEFAULT RECORD
            , location :=       ""
            , croho :=          ""
            ]
          ], rec.product);
    }
    IF (CellExists(rec, "contact"))
    {
      rec.contact := EnforceStructure(
          [ [ userkey :=        ""
            ]
          ], rec.contact);
    }
    IF (CellExists(rec, "event"))
    {
      rec.event := EnforceStructure(
          [ [ userkey :=        ""
            , eventstartdate := DEFAULT DATETIME
            , eventenddate := DEFAULT DATETIME
            ]
          ], rec.event);
    }
    IF (CellExists(rec, "suborganization"))
    {
      rec.suborganization := EnforceStructure(
          [ [ userkey :=        ""
            ]
          ], rec.suborganization);
    }
    IF (CellExists(rec, "media"))
    {
      rec.media := EnforceStructure(
          [ [ userkey :=        ""
            ]
          ], rec.media);
    }
    IF (CellExists(rec, "location"))
    {
      rec.location := EnforceStructure(
          [ [ userkey :=        ""
            , locationname := DEFAULT RECORD
            , brinvolg := ""
            ]
          ], rec.location);
    }
    RETURN rec;
  }

