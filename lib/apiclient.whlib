        [ data :=   [ userkey :=  ""
                    , contacts := STRING[]
                    ]
        ], this->Get(`/organization/${EncodeURL(orgid)}/location/${locationid}`,
                  [ expecterrors := options.allowmissing ? [ "no_such_location" ] : STRING[]
                  ]));

