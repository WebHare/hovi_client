  PUBLIC MACRO DeleteEvent(STRING orgid, STRING eventid)
  {
    this->SendRequestJSON("DELETE", `/organization/${EncodeURL(orgid)}/event/${eventid}`);
  }
>;

PUBLIC OBJECT FUNCTION GetHOVIAPIClient(RECORD options DEFAULTSTO DEFAULT RECORD)
{
  options := ValidateOptions([apiversion := hovieditor_use_apiversion], options);

  BOOLEAN usesingleton := options.apiversion = hovieditor_use_apiversion;

  IF(NOT ObjectExists(currenthoviclient) OR NOT usesingleton)
  {
    STRING baseurl := ReadRegistryKey("hovi_client.apiurl");
    STRING apikey := ReadRegistryKey("hovi_client.apikey");
    IF(apikey = "")
      THROW NEW Exception(`HOVI API key not set`);

    OBJECT newclient := NEW HOVIAPIClient(baseurl, apikey, options);
    IF(NOT usesingleton)
      RETURN newclient;

    currenthoviclient := newclient;
  }

  RETURN currenthoviclient;
}

PUBLIC MACRO __ResetHoviClient()
{
  currenthoviclient := DEFAULT OBJECT;
}

