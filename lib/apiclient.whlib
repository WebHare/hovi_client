CONSTANT STRING ARRAY u_datetimefields :=
    [ "EVENTSTARTDATE", "EVENTENDDATE" ];

CONSTANT STRING ARRAY u_datefields :=
    [ "PRODUCTFORMS.PRODUCTSTARTS.APPLICATIONDEADLINE"
    , "PRODUCTFORMS.PRODUCTSTARTS.APPLICATIONDEADLINENONEU"
    , "PRODUCTFORMS.PRODUCTSTARTS.APPLICATIONDEADLINENL"
    , "PRODUCTFORMS.PRODUCTSTARTS.STARTINGDATE"
    , "PRODUCTFORMS.PRODUCTSTARTS.ENDDATE"
    ];

CONSTANT STRING ARRAY u_moneyfields := [ "PRODUCTFORMS.TUITIONFEES.AMOUNT", "PRODUCTFORMS.STUDYCOSTS.AMOUNT", "CREDITS" ];

/** @param data RECORD or RECORD ARRAY
*/
VARIANT FUNCTION ConvertAddressedField(STRING ARRAY toks, VARIANT data, STRING mode)
{
  IF (TypeID(data) = TypeID(RECORD ARRAY))
  {
    FOREVERY (RECORD elt FROM data)
      data[#elt] := ConvertAddressedField(toks, elt, mode);
    RETURN data;
  }
  IF (NOT CellExists(data, toks[0]))
    RETURN data;

  VARIANT value := GetCell(data, toks[0]);
  IF (LENGTH(toks) > 1)
    value := ConvertAddressedField(ArraySlice(toks, 1), value, mode);
  ELSE
  {
    SWITCH (mode)
    {
      CASE "money-to-text"      { IF (TypeID(value) != TypeID(STRING)) { value := FormatMoney(value, 0, ".", "", FALSE); } }
      CASE "date-to-text"       { IF (TypeID(value) != TypeID(STRING)) { value := FormatDateTime("%Y-%m-%d", value); } }
      CASE "datetime-to-text"   { IF (TypeID(value) != TypeID(STRING)) { value := FormatDateTime("%Y-%m-%dT%H:%M:%SZ", value); } }
      CASE "text-to-money"      { IF (TypeID(value) = TypeID(STRING)) { value := ToMoney(value, 0m); } }
      CASE "text-to-date"       { IF (TypeID(value) = TypeID(STRING)) { value := MakeDateFromText(value); } }
      CASE "text-to-datetime"   { IF (TypeID(value) = TypeID(STRING)) { value := MakeDateFromText(value); } }
      DEFAULT                   { THROW NEW Exception(`Unknown conversion mode ${EncodeJSON(mode)}`); }
    }
  }

  RETURN CellInsert(CellDelete(data, toks[0]), toks[0], value);
}


VARIANT FUNCTION ConvertFieldsForRequest(VARIANT data)
{
  IF (TypeID(data) = TypeID(RECORD) OR TypeID(data) = TypeID(RECORD ARRAY))
  {
    FOREVERY (STRING toks FROM u_moneyfields)
      data := ConvertAddressedField(Tokenize(toks, "."), data, "money-to-text");
    FOREVERY (STRING toks FROM u_datefields)
      data := ConvertAddressedField(Tokenize(toks, "."), data, "date-to-text");
    FOREVERY (STRING toks FROM u_datetimefields)
      data := ConvertAddressedField(Tokenize(toks, "."), data, "datetime-to-text");
  }

  RETURN data;
}

VARIANT FUNCTION ConvertFieldsFromResponse(VARIANT data)
{
  IF (TypeID(data) = TypeID(RECORD) OR TypeID(data) = TypeID(RECORD ARRAY))
  {
    FOREVERY (STRING toks FROM u_moneyfields)
      data := ConvertAddressedField(Tokenize(toks, "."), data, "text-to-money");
    FOREVERY (STRING toks FROM u_datefields)
      data := ConvertAddressedField(Tokenize(toks, "."), data, "text-to-date");
    FOREVERY (STRING toks FROM u_datetimefields)
      data := ConvertAddressedField(Tokenize(toks, "."), data, "text-to-datetime");
  }

  RETURN data;
}

PUBLIC STRING FUNCTION GetHoviClientAPIVersion()
{
  RETURN hovieditor_use_apiversion;
}

PUBLIC STATIC OBJECTTYPE HOVIAPIClient
<
  STRING baseurl;
  OBJECT browser;
  RECORD options;

  MACRO NEW(STRING baseurl, STRING apikey, RECORD options DEFAULTSTO DEFAULT RECORD)
  {
    this->options := ValidateOptions([apiversion := hovieditor_use_apiversion], options);
    this->baseurl := baseurl;
    this->browser := NEW WebBrowser;
    this->browser->SetAuthorization(`*`, `Bearer ${apikey}`);
  }

  PUBLIC VARIANT FUNCTION Get(STRING url, RECORD options DEFAULTSTO DEFAULT RECORD)
  {
    options := ValidateOptions([ expecterrors := STRING[]
                               , convertfields := TRUE
                               ], options);
    IF(url LIKE "/*")
      url := Substring(url,1);

    STRING finalurl := this->baseurl || this->options.apiversion || "/" || url;

    //this->browser->debug := TRUE;
    this->browser->GotoWebPage(finalurl);

    VARIANT response := DecodeJSONBlob(this->browser->content);
    IF (TypeID(response) = TypeID(RECORD) AND IsValueSet(response) AND options.convertfields)
      response := ConvertFieldsFromResponse(response);

    IF(this->browser->GetHTTPStatusCode() >= 500)
    {
      THROW NEW Exception(`Failed to navigate to ${finalurl}: ${this->browser->GetHTTPStatusText()}`);
    }
    ELSE IF(this->browser->GetHTTPStatusCode() >= 400)
    {
      STRING errorcode := EnforceStructure([ errorcode := "" ], response).errorcode;
      IF (errorcode IN options.expecterrors)
      {
        RETURN CELL
          [ etag := ""
          , statuscode :=     this->browser->GetHTTPStatusCode()
          , errorcode
          , data := response
          ]; //expected error
      }

      THROW NEW Exception(`Failed to navigate to ${finalurl}: ${this->browser->GetHTTPStatusText()}`);
    }
    ELSE IF(this->browser->GetHTTPStatusCode() != 200)
    {
      THROW NEW Exception(`Failed to navigate to ${finalurl}: ${this->browser->GetHTTPStatusText()}`);
    }

    RETURN CELL
        [ data :=         response
        , errorcode :=    ""
        , etag :=         this->browser->GetResponseHeader("etag")
        , statuscode :=   this->browser->GetHTTPStatusCode()
        ];
  }

  PUBLIC RECORD FUNCTION SendRequestJSON(STRING method, STRING url, VARIANT postbody DEFAULTSTO DEFAULT RECORD, RECORD options DEFAULTSTO DEFAULT RECORD)
  {
    options := ValidateOptions(
        [ ifmatch :=    ""
        , expecterrors := STRING[]
        ], options);

    RECORD ARRAY headers;
    IF (options.ifmatch != "")
      INSERT [ field := "If-Match", value := options.ifmatch ] INTO headers AT END;

    IF(url LIKE "/*")
      url := Substring(url,1);

    IF (TypeID(postbody) = TypeID(RECORD) AND IsValueSet(postbody))
      postbody := ConvertFieldsForRequest(postbody);

    STRING finalurl := this->baseurl || this->options.apiversion || "/" || url;
    this->browser->SendRawRequest(method, finalurl, [ [ field := "Content-type", value := "application/json" ], ...headers ], EncodeJSONBlob(postbody, __hovieditor_apitranslations));

    VARIANT response := DecodeJSONBlob(this->browser->content);
    IF (TypeID(response) = TypeID(RECORD) AND IsValueSet(response))
      response := ConvertFieldsFromResponse(response);

    IF(this->browser->GetHTTPStatusCode() >= 500)
    {
      THROW NEW Exception(`Failed to navigate to ${finalurl}: ${this->browser->GetHTTPStatusText()}`);
    }
    ELSE IF(this->browser->GetHTTPStatusCode() >= 400)
    {
      STRING errorcode := EnforceStructure([ errorcode := "" ], response).errorcode;
      IF (errorcode IN options.expecterrors)
      {
        RETURN CELL
          [ etag := ""
          , statuscode :=     this->browser->GetHTTPStatusCode()
          , errorcode
          , data := response
          ]; //expected error
      }

      THROW NEW Exception(`Failed to navigate to ${finalurl}: ${this->browser->GetHTTPStatusText()}`);
    }
    ELSE IF(this->browser->GetHTTPStatusCode() >= 300)
    {
      THROW NEW Exception(`Failed to navigate to ${finalurl}: ${this->browser->GetHTTPStatusText()}`);
    }

    IF (TypeID(response) = TypeID(RECORD) AND IsValueSet(response))
      response := ConvertFieldsFromResponse(response);

    RETURN
        [ data :=         response
        , errorcode :=    ""
        , etag :=         this->browser->GetResponseHeader("etag")
        , statuscode :=   this->browser->GetHTTPStatusCode()
        ];
  }

  PUBLIC RECORD FUNCTION GetPermissions()
  {
    RECORD retval := this->Get("/permissions", [ expecterrors := [ "apikey_deactivated", "no_such_apikey", "invalid_authentication_header" ] ]).data;

    IF(CellExists(retval,'errorcode'))
      RETURN DEFAULT RECORD;

    RETURN EnforceStructure([ manageorganizations := STRING[] ], retval);
  }

  PUBLIC RECORD ARRAY FUNCTION GetOrganizations()
  {
    RETURN EnforceStructure(RECORD[], this->Get(`/organization`).data);
  }

  PUBLIC RECORD FUNCTION GetProduct(STRING orgid, STRING productid, RECORD options DEFAULTSTO DEFAULT RECORD)
  {
    options := ValidateOptions(
        [ allowmissing :=   FALSE
        ], options);

    IF(productid = "")
      THROW NEW Exception(`productid is required`);

    //RETURN EnforceStructure([ data := product_structure ], this->Get(`/organization/${EncodeURL(orgid)}/product/${productid}`));
    RECORD retval := this->Get(`/organization/${EncodeURL(orgid)}/product/${productid}`,
                        [ expecterrors := options.allowmissing ? [ "no_such_product" ] : STRING[]
                        ]);

    IF (retval.statuscode = 404) // only when allowmissing is TRUE
      RETURN DEFAULT RECORD;

    RETURN retval;
  }

  PUBLIC RECORD ARRAY FUNCTION GetProducts(STRING orgid)
  {
    RETURN EnforceStructure(
        [ [ userkey :=        ""
          , producttype :=    ""
          , productname :=    DEFAULT RECORD
          , productlevel :=   ""
          , location :=       ""
          , croho :=          ""
          , crohoname :=      DEFAULT RECORD
          ]
        ], this->Get(`/organization/${EncodeURL(orgid)}/product`).data);
  }

