        , icon  :=      "tollium:business/coins"
        , fields :=     [ "tuitionfees", "tuitionfeeincludes", "studycosts", "tuitionfeeurl" ]
        , field :=      ""
        ]
      , [ name :=       "admission"
        , title :=      /*tid*/'hovi_client:itemtypes.product.groups.admission'
        , icon :=       "system:sysmgmt/access"
        , fields :=     [ "productstarts", "admissionurl", "languagerequirements", "studyroutes", "studychoicechecks" ]
        , field :=      ""
        ]
      , [ name :=       "afterstudy"
