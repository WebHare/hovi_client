PUBLIC RECORD ARRAY FUNCTION GetHOVIFieldGrouping(STRING itemtype)
{
  RECORD ARRAY base := GetCell(fieldgroups, itemtype);
  UPDATE base SET title := GetTid(title);
  RETURN base;
}
