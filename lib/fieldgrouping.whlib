          , title :=      /*tid*/'hovi_client:itemtypes.event.groups.idlink'
          , icon :=       "tollium:objects/tag"
          , fields :=     [ "eventconfig", "userkey" ]
          , field :=      ""
          , consumerfields := ["eventtype"]
          ]
        , [ name :=       "general"
          , title :=      /*tid*/'hovi_client:itemtypes.event.groups.general'
          , icon :=       "tollium:actions/properties"
          , fields :=     [ "eventname", "eventplanning", "eventstartdate", "eventenddate", "locationtype", "onlineeventurl"
                          , "locations", "description", "informationregistrationurl",/* "eventlevels", "targetlevels",*/ "participatingproducts", "targetregions"
