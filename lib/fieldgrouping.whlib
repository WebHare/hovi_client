<?wh

LOADLIB "mod::tollium/lib/gettid.whlib";


RECORD fieldgroups :=
  [ product :=
      [ [ name :=       "propertiesfake"
        , title :=      /*tid*/'hovi_client:itemtypes.product.groups.idlink'
        , icon :=       "tollium:objects/tag"
        , fields :=     [ "productconfig", "productname", "productlevel", "programlevel", "crohosector", "soi2006classification", "iscedcluster", "financing"
                        , "isbkkiproduct", "location", "sidelocations", "suborganizations"
                        , "summitcodes", "userkey", "references"
                        ]
        , field :=      ""
        , combinedfields := [ productconfig :=  [ "producttype", "croho", "productform" ]
                            , isbkkiproduct :=  [ "increasedtuitionfeebkki" ]
                            ]
        , consumerfields := ["producttype"]
        ]
      , [ name :=       "general"
        , title :=      /*tid*/'hovi_client:itemtypes.product.groups.general'
        , icon :=       "tollium:actions/properties"
        , fields :=     [ "productdescription", "producturl", "accreditations", "instructionmodes", "instructionmodedescription", "degrees", "contacts", "cooperations", "credits" ]
