<module xmlns="http://www.webhare.net/xmlns/system/moduledefinition">

  <meta configscreen="/tolliumapps/config.xml#config">
    <version>4.1.1</version>
    <description />
    <packaging download="true" webhareversion=">= 5.6.0" />
    <validation options="nowarnings">
      <fetchmodule module="hovi_database" repository="hovi/hovi_database" />
    </validation>
  </meta>

  <moduleregistry>
    <string name="apiurl" description="HOVI API base url" initialval="https://api.hovi.nl/api/" />
    <string name="apikey" description="HOVI API key" />
    <obsoletenode name="skdbclient"/>
    <node name="skdb20client">
      <string name="apiurl" initialval="https://api.skdb.nl/" />
      <string name="apikey" />
    </node>
  </moduleregistry>

  <publisher>
    <siteprofile path="data/hovirtd.siteprl.xml" />
  </publisher>

  <servicemanager>
    <!-- TODO randomizer/offset support -->
    <task runat="30 6 * * *" runtz="Europe/Amsterdam" script="tasks/download_skdb.ts" tag="download_skdb" minservertype="test" />
  </servicemanager>

</module>
