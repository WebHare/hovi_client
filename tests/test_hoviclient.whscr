<?wh

LOADLIB "mod::system/lib/testframework.whlib";

LOADLIB "mod::hovi_client/lib/hovirichtext.whlib";


MACRO TestCleanupHoviHTMLText()
{
  RECORD res;

  res  := CleanupHoviHTMLText("");
  Testeq([ resultlength := 0, normalizedhtml := "" ], res);

  res  := CleanupHoviHTMLText(`<P class='normal'>Hello™&euro;</p>`);
  Testeq([ resultlength := 7, normalizedhtml := "<p>Hello™€</p>" ], res);

  res  := CleanupHoviHTMLText("<P>Hello™&euro;</p>");
  Testeq([ resultlength := 7, normalizedhtml := "<p>Hello™€</p>" ], res);

  res  := CleanupHoviHTMLText(`<p></p><P class='normal'>Hello</p><p></p>`);
  Testeq([ resultlength := 5, normalizedhtml := "<p>Hello</p>" ], res);

  res  := CleanupHoviHTMLText(`<p class='normal'>Hello \neverybody</p>`);
  Testeq([ resultlength := 15, normalizedhtml := "<p>Hello everybody</p>" ], res);

  res  := CleanupHoviHTMLText(`<p class='normal'>Hello\neverybody</p>`);
  Testeq([ resultlength := 15, normalizedhtml := "<p>Hello everybody</p>" ], res);

  res  := CleanupHoviHTMLText(`<ul><li>hi<li>everybody<p>there`);
  Testeq([ resultlength := 16, normalizedhtml := "<ul><li>hi</li><li>everybody</li></ul><p>there</p>" ], res);

  res  := CleanupHoviHTMLText(`<p>opening</p><p></p><ul><li>hi<li><li>everybody<l><p>there`);
  Testeq([ resultlength := 23, normalizedhtml := "<p>opening</p><ul><li>hi</li><li>everybody</li></ul><p>there</p>" ], res);

  res  := CleanupHoviHTMLText(`<p><ul><li><!-- nothing to see here! -->`);
  Testeq([ resultlength := 0, normalizedhtml := "" ], res);

  res  := CleanupHoviHTMLText(`<p class='normal'>Hello<br/>all</p><p><br data-wh-rte=\\"bogus\\"/></p><p class=\\"normal\\">regel 2</p>`);
  Testeq([ resultlength := 15, normalizedhtml := "<p>Hello<br/>all</p><p>regel 2</p>" ], res);

  res  := CleanupHoviHTMLText(`<p class='normal'>Hello<br/>all</p><p></p><p class=\\"normal\\">regel 2</p>`);
  Testeq([ resultlength := 15, normalizedhtml := "<p>Hello<br/>all</p><p>regel 2</p>" ], res);

  res  := CleanupHoviHTMLText(`<p>${RepeatText("A", 2047 - 3 - 4)}`);
  Testeq([ resultlength := 2040, normalizedhtml := `<p>${RepeatText("A", 2047 - 3 - 4)}</p>` ], res);

  res  := CleanupHoviHTMLText('<html><body><p class=\"normal\">Tekst.<br/><br/><\/body><\/html>');
  Testeq([ resultlength := 6, normalizedhtml := `<p>Tekst.<br/></p>` ], res);
  res  := CleanupHoviHTMLText('<html><body><p class=\"normal\">Tekst.<br/><\/body><\/html>');
  Testeq([ resultlength := 6, normalizedhtml := `<p>Tekst.</p>` ], res);

  res  := CleanupHoviHTMLText(`<html><body><p class="normal">Als registerloods ben je de verbindende factor tussen het schip, de verkeersdienst en diverse maritieme partijen daaromheen. Weer of geen weer, zicht of geen zicht; jij loodst veilig alle schepen naar de kade en naar zee. Tankers, bulkcarriers, sleepboten met sleep, drijvende bokken, autocarriers, coasters, reefers, containerschepen, cruiseschepen, noem maar op. Als het drijft, moet jij het door de haven kunnen loodsen. Hiervoor heb je niet alleen kennis over de manoeuvreer- en vaareigenschappen van al die typen schepen, maar beschik je ook over inlevingsvermogen: je hebt namelijk te maken met verschillende mensen en culturen met uiteenlopende nationaliteiten en kwaliteiten.</p><p class="normal"><br data-wh-rte="bogus"></p><p class="normal">Zie jij jezelf werken in één van de Nederlandse en Belgische zeehavens? Wil jij leren om met windkracht 7 dat schip voor de kant te krijgen? Zie jij het als een uitdaging om kapiteins van over de hele wereld te adviseren? Dan zou het beroep van loods wat voor jou kunnen zijn.</p><p class="normal"><br data-wh-rte="bogus"></p><p class="normal">De opleiding tot registerloods is een hbo master geaccrediteerde opleiding. Je dient te beschikken over de volgende startkwalificaties:</p><p class="normal">·&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ruime maritieme ervaring als bijvoorbeeld stuurman</p><p class="normal">·&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; HBO-bachelor diploma</p><p class="normal">·&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; vaarbevoegdheidsbewijs eerste stuurman alle schepen</p><p class="normal">·&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;BRM/MRM certificaat</p><p class="normal">·&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Marcom-A certificaat</p><p class="normal">&nbsp;</p><p class="normal">Middels een werken-leren traject word je in maximaal 15 maanden klaargestoomd voor het echte werk als loods.&nbsp;</p><\/body><\/html>`);
  TestEq(1409, res.resultlength);

  //res  := CleanupHoviHTMLText('<html><body><p class=\"normal\">Tekst.<br/><br data-wh-rte=\"bogus\"/><\/p><\/body><\/html>');
  //Testeq([ resultlength := 6, normalizedhtml := `<p>Tekst.<br/></p>` ], res);
  //res  := CleanupHoviHTMLText('<html><body><p>Tekst.<br/></p><\/body><\/html>');
  //Testeq([ resultlength := 6, normalizedhtml := `<p>Tekst.<br/></p>` ], res);
}

Runtestframework([ PTR TestCleanupHoviHTMLText ]);
